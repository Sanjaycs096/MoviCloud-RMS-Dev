# Backend config
FLASK_ENV=development
FLASK_DEBUG=1

# SQLite DB file path (relative to backend/) — only used by legacy SQLAlchemy models
DATABASE_URL=sqlite:///restaurant.db

# CORS (comma separated). Use * for dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# MongoDB Atlas connection string — REQUIRED
# Same cluster used by Admin side (restaurant_db)
MONGODB_URI=mongodb+srv://priyadharshini:Ezhilithanya@cluster0.crvutrr.mongodb.net/restaurant_db

# API base path
API_PREFIX=/api
